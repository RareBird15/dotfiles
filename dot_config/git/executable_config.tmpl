[user]
    name = Lanie
    email = 13343932+RareBird15@users.noreply.github.com
{{- if eq .chezmoi.hostname "stormux" }}
    signingkey = /home/lanie/.ssh/id_ed25519_pi.pub
{{- end }}

[init]
    defaultBranch = main

[commit]
    gpgsign = true

[gpg]
    format = ssh

{{- if eq .chezmoi.os "linux" }}
  {{- if (contains "microsoft" (.chezmoi.kernel.osrelease | lower)) }}
[core]
    # WSL: Use Windows SSH client to talk to 1Password
    sshCommand = /mnt/c/Windows/System32/OpenSSH/ssh.exe

[gpg "ssh"]
    # WSL: Use the specific 1Password WSL signing helper
    program = "/mnt/c/Users/Windows11/AppData/Local/Microsoft/WindowsApps/op-ssh-sign-wsl.exe"
  {{- end }}
{{- end }}

{{- if eq .chezmoi.os "windows" }}
[gpg "ssh"]
    # Windows: Standard 1Password signing path
    program = "C:/Users/Windows11/AppData/Local/Microsoft/WindowsApps/op-ssh-sign.exe"
{{- end }}

# Mergiraf Syntax-Aware Merge Driver
[merge "mergiraf"]
    name = mergiraf
    driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L
