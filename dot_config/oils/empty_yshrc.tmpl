# ~/.config/oils/yshrc

# Enable all modern YSH features and strict error handling
shopt --set ysh:all
shopt --set errexit

# Set a minimal, screen-reader-friendly prompt
setglobal ENV.PS1 = r'\w \$ '

# =====================
# 0. XDG & ENVIRONMENT
# =====================
# Safely get the username and set the runtime dir
var current_user = $(whoami)
setglobal ENV.XDG_RUNTIME_DIR = "${XDG_RUNTIME_DIR:-/tmp/$current_user-runtime}"

if not test -d "$XDG_RUNTIME_DIR" {
    mkdir -pm 0700 "$XDG_RUNTIME_DIR"
}

setglobal ENV.XDG_CONFIG_HOME = "$HOME/.config"
setglobal ENV.XDG_DATA_HOME = "$HOME/.local/share"
setglobal ENV.XDG_STATE_HOME = "$HOME/.local/state"
setglobal ENV.XDG_CACHE_HOME = "$HOME/.cache"
mkdir -p "$XDG_CONFIG_HOME" "$XDG_DATA_HOME" "$XDG_STATE_HOME" "$XDG_CACHE_HOME"

setglobal ENV.CARGO_HOME = "$XDG_DATA_HOME/cargo"
setglobal ENV.RUSTUP_HOME = "$XDG_DATA_HOME/rustup"
setglobal ENV.GOPATH = "$XDG_DATA_HOME/go"
setglobal ENV.NODE_REPL_HISTORY = "$XDG_STATE_HOME/node_repl_history"
setglobal ENV.NPM_CONFIG_USERCONFIG = "$XDG_CONFIG_HOME/npm/npmrc"
setglobal ENV.HISTFILE = "$XDG_STATE_HOME/ysh_history"
setglobal ENV.INPUTRC = "$XDG_CONFIG_HOME/readline/inputrc"
setglobal ENV.GNUPGHOME = "$XDG_DATA_HOME/gnupg"
setglobal ENV.NPM_CONFIG_CACHE = "$XDG_CACHE_HOME/npm"
setglobal ENV.NPM_CONFIG_TMP = "$XDG_CACHE_HOME/npm_tmp"
setglobal ENV.RANDFILE = "$XDG_STATE_HOME/openssl_rnd"
setglobal ENV.PYTHON_HISTORY = "$XDG_STATE_HOME/python_history"
setglobal ENV.SCREENRC = "$XDG_CONFIG_HOME/screen/screenrc"
setglobal ENV.XINITRC = "$XDG_CONFIG_HOME/X11/xinitrc"
setglobal ENV.CODEX_HOME = "$XDG_CONFIG_HOME/codex"

# Device-Specific Environment Tweaks
{{- if eq .chezmoi.os "linux" }}
  {{- if and (hasKey .chezmoi.kernel "osrelease") (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
    setglobal ENV.BROWSER = "wslview"
  {{- else if eq .chezmoi.hostname "stormux" }}
    setglobal ENV.OP_BIOMETRIC_UNLOCK_ENABLED = "false"
  {{- end }}
{{- end }}

setglobal ENV.PAGER = "less -Ri"

# =====================
# 1. Exported Variables
# =====================
setglobal ENV.EXA_API_KEY = '{{ onepasswordRead "op://Personal/Exa API Key/credential" }}'
setglobal ENV.GITHUB_PERSONAL_ACCESS_TOKEN = '{{ onepasswordRead "op://Personal/GitHub MCP Server Token/credential" }}'
setglobal ENV.GOOGLE_CLIENT_ID = '{{ onepasswordRead "op://Personal/Google Cloud MCP-Omnibus Keys/username" }}'
setglobal ENV.GOOGLE_CLIENT_SECRET = '{{ onepasswordRead "op://Personal/Google Cloud MCP-Omnibus Keys/credential" }}'

# =====================
# 2. PATH
# =====================
setglobal ENV.PATH = "$HOME/.local/bin:$HOME/bin:$HOME/.local/share/npm-global/bin:$CARGO_HOME/bin:$GOPATH/bin:$PATH"

# =====================
# 3. EDITOR & DIALOGS
# =====================
setglobal ENV.EDITOR = "code-insiders --wait"
setglobal ENV.VISUAL = "code-insiders --wait"

{{- if eq .chezmoi.os "linux" }}
  {{- if hasKey .chezmoi.kernel "osrelease" }}
    {{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
      setglobal ENV.SUDO_EDITOR = "/mnt/c/Users/Windows11/AppData/Local/Programs/Microsoft VS Code Insiders/bin/code-insiders --wait"
    {{- end }}
  {{- end }}
{{- end }}

setglobal ENV.DIALOGOPTS = "--no-lines --visit-items"
setglobal ENV.GPG_TTY = $(tty 2>/dev/null)

# =====================
# 4. COMPLETION SUPPORT
# =====================
if test -r /usr/share/bash-completion/bash_completion {
    source /usr/share/bash-completion/bash_completion
}

# =====================
# 5. ALIASES & EXPORTS
# =====================
alias ll='eza -l'
alias la='eza -la'
alias lt='eza --tree'
alias lta='eza --tree -a'
alias wget="wget --hsts-file=$XDG_CACHE_HOME/wget-hsts"
alias fp='fzf --preview "bat --style=numbers --color=always --line-range :500 {}"'
alias rg='rg --smart-case'
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ex='cd ~/exercism'

# Using standard proc syntax
proc pj {
    var dir = $(zoxide query -l | fzf --height 40% --reverse --header="Jump to directory")
    if test -n "$dir" { cd "$dir" }
}

alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git pull'
alias gd='git diff'
alias gco='git checkout'
alias gb='git branch'
alias gcb='git checkout -b'

alias cz='chezmoi'
alias cza='chezmoi apply'
alias cze='chezmoi edit'
alias c='clear'
alias reload='source ~/.config/oils/yshrc'

{{- if eq .chezmoi.os "linux" }}
  {{- if hasKey .chezmoi.kernel "osrelease" }}
    {{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
      unalias open 2>/dev/null
      if command -v wslview >/dev/null 2>&1 {
          alias open='wslview'
      }
      alias winpath='wslpath -w'
      alias clip='clip.exe'
      alias winget='winget.exe'
    {{- end }}
  {{- end }}

proc export_linux_packages {
    var dir = "$HOME/.local/share/chezmoi/package-lists/linux"
    mkdir -p "$dir"
    echo "Exporting Linux package lists to $dir..."

    if command -v pacman >/dev/null 2>&1 { pacman -Qqe > "$dir/pacman.txt" }
    if command -v cargo >/dev/null 2>&1  { cargo install --list > "$dir/cargo.txt" }
    if command -v uv >/dev/null 2>&1     { uv tool list > "$dir/uv.txt" }
    if command -v npm >/dev/null 2>&1    { npm list -g --depth=0 > "$dir/npm.txt" }
    if command -v pip >/dev/null 2>&1    { pip list > "$dir/pip.txt" }

    echo "Done! Lists saved to chezmoi source."
}
alias expl='export_linux_packages'
{{- end }}

alias ls='eza --icons --group-directories-first'
alias cat='bat --paging=never'
alias du='dust'
alias ch='choose'
alias tldr='tldr'

alias qk='cd ~/qmk_firmware/keyboards/keychron/k10_max/ansi/rgb/keymaps/lanie/'
alias qkf='cd ~/qmk_firmware && qk && qmk flash -kb keychron/k10_max/ansi/rgb -km lanie'

# =====================
# 6. APP INTEGRATIONS
# =====================
if test -f ~/.cache/bash_inits/fzf.bash { source ~/.cache/bash_inits/fzf.bash }
if test -f ~/.cache/bash_inits/zoxide.bash { source ~/.cache/bash_inits/zoxide.bash }
if test -f ~/.cache/bash_inits/pieces.bash { source ~/.cache/bash_inits/pieces.bash }
if test -f ~/.cache/bash_inits/starship.bash { source ~/.cache/bash_inits/starship.bash }

if command -v tldr >/dev/null 2>&1 {
    tldr --update >/dev/null 2>&1 &
}

# =====================
# 7. CUSTOM FUNCTIONS & REMINDERS
# =====================
proc bible_reader_reminder {
    var bin_file = "$HOME/projects/bible-reader/.venv/bin/maybe-read-bible"
    var stamp_file = "$HOME/.local/state/bible-reader/last_prompt_date.txt"

    if not test -f "$bin_file" { return }

    var today = $(date +%F)
    if test -f "$stamp_file" {
        var last_stamp = $(cat "$stamp_file" 2>/dev/null)
        if (last_stamp == today) { return }
    }

    echo "\nBible reading pending. Run: br\n"
}

alias br='"$HOME/projects/bible-reader/.venv/bin/maybe-read-bible"'

bible_reader_reminder

proc sanitize_blog (file) {
    if test -z "$file" {
        echo "Usage: sanitize_blog <filename>"
        return 1
    }

    echo "Cleaning $file..."
    sed -i -e 's/- \[[ x]\] .*//g' "$file"
    sed -i -e '/^$/N;/^\n$/D' "$file"
    echo "Logic preserved. File cleaned."
}
