# ~/.config/oils/yshrc

# Enable modern YSH features
shopt --set ysh:all
shopt --set expand_aliases
shopt --set errexit nounset

# Set a minimal, screen-reader-friendly prompt
setglobal ENV.PS1 = r'\w \$ '

# =====================
# 0. XDG & ENVIRONMENT
# =====================
var my_home = "$HOME"
var my_user = $(whoami)

var runtime_dir = "/tmp/$my_user-runtime"
mkdir -pm 0700 "$runtime_dir"

var config_home = "$my_home/.config"
var data_home = "$my_home/.local/share"
var state_home = "$my_home/.local/state"
var cache_home = "$my_home/.cache"
mkdir -p "$config_home" "$data_home" "$state_home" "$cache_home"

setglobal ENV.XDG_RUNTIME_DIR = runtime_dir
setglobal ENV.XDG_CONFIG_HOME = config_home
setglobal ENV.XDG_DATA_HOME = data_home
setglobal ENV.XDG_STATE_HOME = state_home
setglobal ENV.XDG_CACHE_HOME = cache_home

var cargo_home = "$data_home/cargo"
var rustup_home = "$data_home/rustup"
var go_path = "$data_home/go"

setglobal ENV.CARGO_HOME = cargo_home
setglobal ENV.RUSTUP_HOME = rustup_home
setglobal ENV.GOPATH = go_path
setglobal ENV.NODE_REPL_HISTORY = "$state_home/node_repl_history"
setglobal ENV.NPM_CONFIG_USERCONFIG = "$config_home/npm/npmrc"
setglobal ENV.HISTFILE = "$state_home/ysh_history"
setglobal ENV.INPUTRC = "$config_home/readline/inputrc"
setglobal ENV.GNUPGHOME = "$data_home/gnupg"
setglobal ENV.NPM_CONFIG_CACHE = "$cache_home/npm"
setglobal ENV.NPM_CONFIG_TMP = "$cache_home/npm_tmp"
setglobal ENV.RANDFILE = "$state_home/openssl_rnd"
setglobal ENV.PYTHON_HISTORY = "$state_home/python_history"
setglobal ENV.SCREENRC = "$config_home/screen/screenrc"
setglobal ENV.XINITRC = "$config_home/X11/xinitrc"
setglobal ENV.CODEX_HOME = "$config_home/codex"

# Device-Specific Environment Tweaks
{{- if eq .chezmoi.os "linux" }}
  {{- if and (hasKey .chezmoi.kernel "osrelease") (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
    setglobal ENV.BROWSER = "wslview"
  {{- else if eq .chezmoi.hostname "stormux" }}
    setglobal ENV.OP_BIOMETRIC_UNLOCK_ENABLED = "false"
  {{- end }}
{{- end }}

setglobal ENV.PAGER = "less -Ri"

# =====================
# 1. Exported Variables
# =====================
setglobal ENV.EXA_API_KEY = {{ onepasswordRead "op://Personal/Exa API Key/credential" | quote }}
setglobal ENV.GITHUB_PERSONAL_ACCESS_TOKEN = {{ onepasswordRead "op://Personal/GitHub MCP Server Token/credential" | quote }}
setglobal ENV.GOOGLE_CLIENT_ID = {{ onepasswordRead "op://Personal/Google Cloud MCP-Omnibus Keys/username" | quote }}
setglobal ENV.GOOGLE_CLIENT_SECRET = {{ onepasswordRead "op://Personal/Google Cloud MCP-Omnibus Keys/credential" | quote }}

# =====================
# 2. PATH
# =====================
setglobal ENV.PATH = "$my_home/.local/bin:$my_home/bin:$my_home/.local/share/npm-global/bin:$cargo_home/bin:$go_path/bin:$PATH"

# =====================
# 3. EDITOR & DIALOGS
# =====================
setglobal ENV.EDITOR = "code-insiders --wait"
setglobal ENV.VISUAL = "code-insiders --wait"

{{- if eq .chezmoi.os "linux" }}
  {{- if hasKey .chezmoi.kernel "osrelease" }}
    {{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
      setglobal ENV.SUDO_EDITOR = "/mnt/c/Users/Windows11/AppData/Local/Programs/Microsoft VS Code Insiders/bin/code-insiders --wait"
    {{- end }}
  {{- end }}
{{- end }}

setglobal ENV.DIALOGOPTS = "--no-lines --visit-items"
setglobal ENV.GPG_TTY = $(tty 2>/dev/null)

# =====================
# 4. COMPLETION SUPPORT
# =====================
if test -r /usr/share/bash-completion/bash_completion {
    shopt --unset errexit nounset
    source /usr/share/bash-completion/bash_completion
    shopt --set errexit nounset
}

# =====================
# 5. ALIASES & EXPORTS
# =====================
alias ll='eza -l'
alias la='eza -la'
alias lt='eza --tree'
alias lta='eza --tree -a'
alias wget="wget --hsts-file=$XDG_CACHE_HOME/wget-hsts"
alias fp='fzf --preview "bat --style=numbers --color=always --line-range :500 {}"'
alias rg='rg --smart-case'
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ex='cd ~/exercism'

# pj uses "|| true" so pressing Esc in fzf doesn't crash the shell
proc pj {
    var dir = $(zoxide query -l | fzf --height 40% --reverse --header="Jump to directory" || true)
    if (dir !== '') { cd "$dir" }
}

alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git pull'
alias gd='git diff'
alias gco='git checkout'
alias gb='git branch'
alias gcb='git checkout -b'

alias cz='chezmoi'
alias cza='chezmoi apply'
alias cze='chezmoi edit'
alias c='clear'
alias reload='source ~/.config/oils/yshrc'

{{- if eq .chezmoi.os "linux" }}
  {{- if hasKey .chezmoi.kernel "osrelease" }}
    {{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
      unalias open 2>/dev/null
      if command -v wslview >/dev/null 2>&1 {
          alias open='wslview'
      }
      alias winpath='wslpath -w'
      alias clip='clip.exe'
      alias winget='winget.exe'
    {{- end }}
  {{- end }}

proc export_linux_packages {
    var dir = "$my_home/.local/share/chezmoi/package-lists/linux"
    mkdir -p "$dir"
    echo "Exporting Linux package lists to $dir..."

    if command -v pacman >/dev/null 2>&1 { pacman -Qqe > "$dir/pacman.txt" }
    if command -v cargo >/dev/null 2>&1  { cargo install --list > "$dir/cargo.txt" }
    if command -v uv >/dev/null 2>&1     { uv tool list > "$dir/uv.txt" }
    if command -v npm >/dev/null 2>&1    { npm list -g --depth=0 > "$dir/npm.txt" }
    if command -v pip >/dev/null 2>&1    { pip list > "$dir/pip.txt" }

    echo "Done! Lists saved to chezmoi source."
}
alias expl='export_linux_packages'
{{- end }}

alias ls='eza --icons --group-directories-first'
alias cat='bat --paging=never'
alias du='dust'
alias ch='choose'
alias tldr='tldr'

alias qk='cd ~/qmk_firmware/keyboards/keychron/k10_max/ansi/rgb/keymaps/lanie/'
alias qkf='cd ~/qmk_firmware && qk && qmk flash -kb keychron/k10_max/ansi/rgb -km lanie'

# =====================
# 6. APP INTEGRATIONS
# =====================
# Disable strict mode before loading messy Bash scripts
shopt --unset errexit nounset

if test -f ~/.cache/bash_inits/fzf.bash { source ~/.cache/bash_inits/fzf.bash }
if test -f ~/.cache/bash_inits/zoxide.bash { source ~/.cache/bash_inits/zoxide.bash }
if test -f ~/.cache/bash_inits/pieces.bash { source ~/.cache/bash_inits/pieces.bash }
if test -f ~/.cache/bash_inits/starship.bash { source ~/.cache/bash_inits/starship.bash }

# Turn strict mode back on
shopt --set errexit nounset

if command -v tldr >/dev/null 2>&1 {
    tldr --update >/dev/null 2>&1 || true &
}

# =====================
# 7. CUSTOM FUNCTIONS & REMINDERS
# =====================
proc bible_reader_reminder {
    var bin_file = "$my_home/projects/bible-reader/.venv/bin/maybe-read-bible"
    var stamp_file = "$my_home/.local/state/bible-reader/last_prompt_date.txt"

    if ! test -f "$bin_file" { return 0 }

    var today = $(date +%F)
    if test -f "$stamp_file" {
        # Using || echo "none" prevents errexit crashes if cat fails
        var last_stamp = $(cat "$stamp_file" 2>/dev/null || echo "none")
        if (last_stamp === today) { return 0 }
    }

    echo ""
    echo "Bible reading pending. Run: br"
    echo ""
}

alias br='$HOME/projects/bible-reader/.venv/bin/maybe-read-bible'

bible_reader_reminder

proc sanitize_blog {
    # Check for arguments safely before trying to read them
    if test "$#" -eq 0 {
        echo "Usage: sanitize_blog <filename>"
        return 1
    }

    var file = "$1"
    echo "Cleaning $file..."
    sed -i -e 's/- \[[ x]\] .*//g' "$file"
    sed -i -e '/^$/N;/^\n$/D' "$file"
    echo "Logic preserved. File cleaned."
}
