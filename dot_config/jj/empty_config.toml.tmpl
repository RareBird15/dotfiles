[user]
name = "Lanie"
email = "13343932+RareBird15@users.noreply.github.com"

[ui]
default-command = "status"
# Since you use bat, this ensures your diffs are clean and accessible
pager = "bat --color=always"

[git]
# Keeps your .jj and .git folders in sync automatically
colocate = true

[signing]
sign-all = true
backend = "ssh"

{{- if eq .chezmoi.hostname "stormux" }}
# Use your Pi-specific SSH key path
key = "/home/lanie/.ssh/id_ed25519_pi.pub"
{{- else }}
# On other systems, 1Password usually recognizes your email as the key identity
key = "13343932+RareBird15@users.noreply.github.com"
{{- end }}

[signing.backends.ssh]
{{- if eq .chezmoi.os "linux" }}
  {{- if (contains "microsoft" (.chezmoi.kernel.osrelease | lower)) }}
# WSL: Mirroring your 1Password signing helper path
program = "/mnt/c/Users/Windows11/AppData/Local/Microsoft/WindowsApps/op-ssh-sign-wsl.exe"
  {{- end }}
{{- else if eq .chezmoi.os "windows" }}
# Windows: Mirroring your 1Password signing helper path
program = "C:/Users/Windows11/AppData/Local/Microsoft/WindowsApps/op-ssh-sign.exe"
{{- end }}
